# Application
APP_NAME=AI SQL Assistant
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (SQLite default, swap to PostgreSQL in production)
DATABASE_URL=sqlite+aiosqlite:///./ai_sql_assistant.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_sql_assistant

# PostgreSQL (for production)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ai_sql_assistant
POSTGRES_PASSWORD=ai_sql_assistant_password
POSTGRES_DB=ai_sql_assistant

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# LLM Providers
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama3-8b-8192
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-1.5-flash
DEFAULT_LLM_PROVIDER=groq

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,txt,csv,docx,md

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Voice
WHISPER_MODEL=base
TTS_LANGUAGE=en

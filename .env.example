# AI SQL Assistant Environment Variables

## Backend
Copy this to backend/.env

# Application
APP_NAME=AI SQL Assistant
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (SQLite default, swap to PostgreSQL in production)
DATABASE_URL=sqlite+aiosqlite:///./ai_sql_assistant.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_sql_assistant

# Redis
REDIS_URL=redis://localhost:6379

# LLM Providers
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-google-api-key
LLM_PROVIDER=groq
GROQ_MODEL=llama3-8b-8192
GEMINI_MODEL=gemini-1.5-flash

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

## Frontend
Copy this to frontend/.env.local

VITE_API_URL=http://localhost:8000/api/v1